# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Redis 配置
REDIS_URL=redis://localhost:6379

# 服务端口
GOSPIDER_PORT=3000
RUSTSPIDER_PORT=3001
PYSPIDER_PORT=5010
JAVASPIDER_PORT=8080

# 输出目录
OUTPUT_DIR=./output
VIDEO_DIR=./videos
CACHE_DIR=./cache

# 日志级别 (info/warn/error/debug)
LOG_LEVEL=info

# 爬虫默认配置
DEFAULT_DEPTH=3
DEFAULT_THREADS=10
DEFAULT_TIMEOUT=30000

# API 密钥（如果使用了 API 服务）
GOOGLE_API_KEY=
BING_API_KEY=
