{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superspider.local/contracts/runtime-core.schema.json",
  "title": "Spider Runtime Core Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request",
    "fingerprint",
    "frontier",
    "scheduler",
    "middleware",
    "artifact_store",
    "session_pool",
    "proxy_policy",
    "observability",
    "cache"
  ],
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "method", "headers", "meta", "priority"],
      "properties": {
        "url": { "type": "string", "format": "uri-reference" },
        "method": { "type": "string" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "cookies": { "type": "object", "additionalProperties": { "type": "string" } },
        "body": { "type": ["string", "null"] },
        "meta": { "type": "object" },
        "priority": { "type": "integer" },
        "depth": { "type": "integer", "minimum": 0 }
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["sha256", "md5"] },
        "value": { "type": "string", "minLength": 32 }
      }
    },
    "frontier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "autoscale",
        "min_concurrency",
        "max_concurrency",
        "lease_ttl_seconds",
        "max_inflight_per_domain",
        "checkpoint_id",
        "checkpoint_dir"
      ],
      "properties": {
        "autoscale": { "type": "boolean" },
        "min_concurrency": { "type": "integer", "minimum": 1 },
        "max_concurrency": { "type": "integer", "minimum": 1 },
        "lease_ttl_seconds": { "type": "integer", "minimum": 1 },
        "max_inflight_per_domain": { "type": "integer", "minimum": 1 },
        "checkpoint_id": { "type": "string", "minLength": 1 },
        "checkpoint_dir": { "type": "string", "minLength": 1 }
      }
    },
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dedup", "priority_queue", "checkpoint_resume"],
      "properties": {
        "dedup": { "type": "boolean" },
        "priority_queue": { "type": "boolean" },
        "checkpoint_resume": { "type": "boolean" }
      }
    },
    "middleware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_hooks", "response_hooks"],
      "properties": {
        "request_hooks": { "type": "integer", "minimum": 0 },
        "response_hooks": { "type": "integer", "minimum": 0 }
      }
    },
    "artifact_store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "root"],
      "properties": {
        "kind": { "type": "string", "enum": ["file", "memory"] },
        "root": { "type": "string", "minLength": 1 }
      }
    },
    "session_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_sessions"],
      "properties": {
        "max_sessions": { "type": "integer", "minimum": 1 }
      }
    },
    "proxy_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": { "type": "string", "enum": ["score", "round-robin"] }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structured_logs", "metrics", "trace", "failure_classification"],
      "properties": {
        "structured_logs": { "type": "boolean" },
        "metrics": { "type": "boolean" },
        "trace": { "type": "boolean" },
        "failure_classification": { "type": "boolean" }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "store_path", "delta_fetch", "revalidate_seconds"],
      "properties": {
        "enabled": { "type": "boolean" },
        "store_path": { "type": "string", "minLength": 1 },
        "delta_fetch": { "type": "boolean" },
        "revalidate_seconds": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
