{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superspider.local/contracts/graph.schema.json",
  "title": "Spider Graph Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["root_id", "nodes", "edges", "stats"],
  "properties": {
    "root_id": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "edges": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_nodes", "total_edges"],
      "properties": {
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "node_types": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
