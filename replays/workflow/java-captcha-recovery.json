{
  "name": "java-captcha-recovery",
  "framework": "javaspider",
  "fixture_path": "replays/workflow/fixtures/java-captcha-recovery.html",
  "target": {
    "url": "https://target.example/challenge"
  },
  "output": {
    "format": "json",
    "path": "artifacts/workflow/java-captcha-recovery.json"
  },
  "output_contract": {
    "format": "json",
    "captcha": {
      "auto_solve": true,
      "mock_solution": "1234",
      "submit_selector": "#continue",
      "fail_on_unsolved": true
    }
  },
  "metadata": {
    "mock_title": "Recovered Dashboard",
    "mock_url": "https://target.example/challenge",
    "mock_challenge_detected": true,
    "mock_captcha_detected": true,
    "mock_proxy_health": "healthy",
    "mock_artifact_content": "java-workflow-replay-artifact",
    "mock_action_log": [],
    "mock_recovery_result": {
      "solved": true,
      "solver": "mock",
      "continued": true,
      "solution_length": 4
    }
  },
  "steps": [
    {
      "id": "goto",
      "type": "GOTO",
      "metadata": {
        "url": "https://target.example/challenge"
      }
    },
    {
      "id": "type-captcha",
      "type": "TYPE",
      "selector": "#captcha",
      "value": "1234",
      "metadata": {}
    },
    {
      "id": "click-continue",
      "type": "CLICK",
      "selector": "#continue",
      "metadata": {}
    },
    {
      "id": "extract-title",
      "type": "EXTRACT",
      "metadata": {
        "field": "title"
      }
    },
    {
      "id": "capture",
      "type": "SCREENSHOT",
      "value": "artifacts/workflow/java-captcha-recovery.txt",
      "metadata": {
        "artifact": "artifacts/workflow/java-captcha-recovery.txt"
      }
    }
  ],
  "expected_audit_types": [
    "proxy.health",
    "challenge.detected",
    "captcha.detected",
    "captcha.solved",
    "job.completed"
  ],
  "expected_actions": [
    "goto:https://target.example/challenge",
    "type:#captcha=1234",
    "click:#continue",
    "shot:"
  ],
  "expected_extract": {
    "title": "Recovered Dashboard"
  },
  "expected_artifact_contains": "java-workflow-replay-artifact"
}
