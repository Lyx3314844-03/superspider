{
  "name": "py-ai-recovery",
  "framework": "pyspider",
  "runtime": "ai",
  "fixture_path": "node-reverse-server/fixtures/anti-bot/datadome-block.html",
  "target": {
    "url": "https://target.example/challenge"
  },
  "output": {
    "format": "json",
    "path": "artifacts/workflow/py-ai-recovery.json"
  },
  "extract": [
    { "field": "title", "type": "ai" }
  ],
  "metadata": {
    "content": "<title>Py Replay Recovery</title>",
    "mock_antibot": {
      "challenge": "captcha",
      "fingerprint_profile": "py-replay",
      "session_mode": "sticky",
      "stealth": true
    },
    "mock_recovery": {
      "strategy": "captcha-solve",
      "recovered": true,
      "events": [
        { "phase": "detect", "signal": "captcha", "status": "passed" },
        { "phase": "mitigate", "action": "solve", "status": "passed" },
        { "phase": "resume", "action": "continue", "status": "passed" }
      ]
    },
    "mock_warnings": ["py replay recovery"]
  },
  "expected_extract": {
    "title": "Py Replay Recovery"
  },
  "expected_warning": "py replay recovery",
  "expected_recovery_strategy": "captcha-solve"
}
