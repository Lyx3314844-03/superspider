{
  "name": "rust-media-recovery",
  "framework": "rustspider",
  "runtime": "media",
  "fixture_path": "node-reverse-server/fixtures/anti-bot/cloudflare-challenge.html",
  "target": {
    "url": "https://target.example/video",
    "body": "playlist.m3u8"
  },
  "output": {
    "format": "json",
    "path": "artifacts/workflow/rust-media-recovery.json"
  },
  "metadata": {
    "mock_antibot": {
      "challenge": "javascript",
      "fingerprint_profile": "rust-replay",
      "session_mode": "sticky",
      "stealth": true
    },
    "mock_recovery": {
      "strategy": "challenge-bypass",
      "recovered": true,
      "events": [
        { "phase": "detect", "signal": "javascript", "status": "passed" },
        { "phase": "mitigate", "action": "bypass", "status": "passed" },
        { "phase": "resume", "action": "continue", "status": "passed" }
      ]
    },
    "mock_warnings": ["rust replay recovery"]
  },
  "expected_detected_media": "hls",
  "expected_warning": "rust replay recovery",
  "expected_recovery_strategy": "challenge-bypass"
}
