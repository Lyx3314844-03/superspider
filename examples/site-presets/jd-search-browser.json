{
  "name": "jd-search-browser",
  "runtime": "browser",
  "target": {
    "url": "https://search.jd.com/Search?keyword=iphone",
    "method": "GET",
    "allowed_domains": ["jd.com", "3.cn"]
  },
  "browser": {
    "headless": true,
    "wait_load": true,
    "viewport": { "width": 1440, "height": 1400 },
    "capture": ["html", "dom", "screenshot", "network"]
  },
  "actions": [
    { "type": "wait" },
    { "type": "scroll" },
    { "type": "wait" }
  ],
  "extract": [
    { "field": "title", "type": "css", "expr": "title" },
    { "field": "sku", "type": "regex", "expr": "(?:sku|wareId|skuId)[\"'=:\\s]+([A-Za-z0-9_-]+)" },
    { "field": "price", "type": "regex", "expr": "(?:￥|¥)\\s?([0-9]+(?:\\.[0-9]{1,2})?)" }
  ],
  "output": { "format": "json", "path": "artifacts/exports/jd-search-browser.json" },
  "metadata": {
    "site_family": "jd",
    "crawler_type": "ecommerce_search"
  }
}
