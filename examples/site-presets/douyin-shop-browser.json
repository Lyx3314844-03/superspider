{
  "name": "douyin-shop-browser",
  "runtime": "browser",
  "target": {
    "url": "https://www.douyin.com/search/iphone",
    "method": "GET",
    "allowed_domains": ["douyin.com", "jinritemai.com"]
  },
  "browser": {
    "headless": true,
    "wait_load": true,
    "viewport": { "width": 1440, "height": 1400 },
    "capture": ["html", "dom", "screenshot", "network"]
  },
  "actions": [
    { "type": "wait" },
    { "type": "scroll" },
    { "type": "wait" }
  ],
  "extract": [
    { "field": "title", "type": "css", "expr": "title" },
    { "field": "product_id", "type": "regex", "expr": "(?:productId|product_id|promotion_id)[\"'=:\\s]+([A-Za-z0-9_-]+)" }
  ],
  "output": { "format": "json", "path": "artifacts/exports/douyin-shop-browser.json" },
  "metadata": {
    "site_family": "douyin-shop",
    "crawler_type": "hydrated_spa"
  }
}
