{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-ecosystem-readiness.schema.json",
  "title": "Spider Ecosystem Readiness Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "checks"],
  "properties": {
    "command": { "const": "verify-ecosystem-readiness" },
    "summary": { "type": "string", "enum": ["passed", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "details"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["passed", "failed"] },
          "details": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
