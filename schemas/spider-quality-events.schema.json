{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-quality-events.schema.json",
  "title": "Spider Quality Events Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "events", "resolved_events", "history"],
  "properties": {
    "command": { "const": "verify-quality-events" },
    "summary": { "type": "string", "enum": ["passed", "warning", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "events": { "type": "array" },
    "resolved_events": { "type": "array" },
    "history": { "type": "object" }
  }
}
