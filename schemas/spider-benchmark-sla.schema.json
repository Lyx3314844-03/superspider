{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-benchmark-sla.schema.json",
  "title": "Spider Benchmark And SLA Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "frameworks"],
  "properties": {
    "command": { "const": "verify-benchmark-sla" },
    "summary": { "type": "string", "enum": ["passed", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "frameworks": { "type": "array" }
  }
}
