{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-superspider-control-plane-report.schema.json",
  "title": "SuperSpider Control Plane Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "checks", "frameworks", "dispatch_plans"],
  "properties": {
    "command": { "const": "verify-superspider-control-plane" },
    "summary": { "type": "string", "enum": ["passed", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "checks": { "type": "array" },
    "frameworks": { "type": "object" },
    "dispatch_plans": { "type": "array" }
  }
}
