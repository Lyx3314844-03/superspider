{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-quality-thresholds.schema.json",
  "title": "Spider Quality Threshold Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "checks", "dashboard_summary", "scorecard_summary"],
  "properties": {
    "command": { "const": "verify-quality-thresholds" },
    "summary": { "type": "string", "enum": ["passed", "warning", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["framework", "name", "status", "details"],
        "properties": {
          "framework": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
          "details": { "type": "string" }
        }
      }
    },
    "dashboard_summary": { "type": "string", "enum": ["passed", "failed"] },
    "scorecard_summary": { "type": "string", "enum": ["passed", "failed"] }
  }
}
