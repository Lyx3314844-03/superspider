{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-doctor-report.schema.json",
  "title": "Spider Doctor Report Contract",
  "type": "object",
  "required": [
    "command",
    "runtime",
    "summary",
    "summary_text",
    "exit_code",
    "checks"
  ],
  "properties": {
    "command": {
      "const": "doctor"
    },
    "runtime": {
      "type": "string",
      "enum": ["java", "go", "rust", "python"]
    },
    "summary": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "details"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "warning", "skipped"]
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
