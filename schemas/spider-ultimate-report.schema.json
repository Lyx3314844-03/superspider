{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-ultimate-report.schema.json",
  "title": "Spider Ultimate Report Contract",
  "type": "object",
  "required": [
    "command",
    "runtime",
    "summary",
    "summary_text",
    "exit_code",
    "url_count",
    "result_count",
    "results"
  ],
  "properties": {
    "command": {
      "const": "ultimate"
    },
    "runtime": {
      "type": "string",
      "enum": ["java", "go", "rust", "python"]
    },
    "summary": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "url_count": {
      "type": "integer",
      "minimum": 0
    },
    "result_count": {
      "type": "integer",
      "minimum": 0
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "url",
          "success",
          "error",
          "duration",
          "anti_bot_level",
          "anti_bot_signals"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "success": {
            "type": "boolean"
          },
          "error": {
            "type": ["string", "null"]
          },
          "duration": {
            "type": "string",
            "minLength": 1
          },
          "anti_bot_level": {
            "type": ["string", "null"]
          },
          "anti_bot_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proxy_used": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
