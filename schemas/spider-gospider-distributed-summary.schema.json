{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-gospider-distributed-summary.schema.json",
  "title": "GoSpider Distributed Summary",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "runtime", "checks", "metrics"],
  "properties": {
    "command": { "const": "verify-gospider-distributed-summary" },
    "summary": { "type": "string", "enum": ["passed", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "runtime": { "const": "go" },
    "checks": { "type": "array" },
    "metrics": { "type": "object" }
  }
}
