{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-replay-dashboard.schema.json",
  "title": "Spider Replay Dashboard Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "sections", "framework_scores"],
  "properties": {
    "command": { "const": "verify-replay-dashboard" },
    "summary": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "sections": {
      "type": "object",
      "required": ["antibot_replays", "workflow_replays", "runtime_readiness", "gospider_distributed_summary", "javaspider_captcha_summary", "pyspider_concurrency_summary", "rust_browser_summary"]
    },
    "framework_scores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "runtime",
          "success_rate",
          "resilience_rate",
          "consistency_rate",
          "artifact_integrity_rate",
          "anti_bot_scenario_rate",
          "recovery_signal_rate",
          "workflow_replay_rate"
        ]
      }
    }
  }
}
