{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-replay-trends.schema.json",
  "title": "Spider Replay Trends Report",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "current", "history", "framework_trends", "scorecard_trends", "policy_trends", "governance_trends", "alerts"],
  "properties": {
    "command": { "const": "verify-replay-trends" },
    "summary": {
      "type": "string",
      "enum": ["passed", "warning", "failed"]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "current": { "type": "object" },
    "history": {
      "type": "object",
      "required": ["count", "latest", "latest_source"]
    },
    "framework_trends": {
      "type": "object"
    },
    "scorecard_trends": {
      "type": "object"
    },
    "policy_trends": {
      "type": "object"
    },
    "governance_trends": {
      "type": "object"
    },
    "alerts": {
      "type": "array"
    }
  }
}
