{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-runtime-stability.schema.json",
  "title": "Spider Runtime Stability Report Contract",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "frameworks"],
  "properties": {
    "command": { "const": "verify-runtime-stability" },
    "summary": { "type": "string", "enum": ["passed", "failed"] },
    "summary_text": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer", "enum": [0, 1] },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "runtime", "summary", "exit_code", "metrics", "checks"],
        "properties": {
          "name": { "type": "string", "enum": ["javaspider", "pyspider", "gospider", "rustspider"] },
          "runtime": { "type": "string", "enum": ["java", "python", "go", "rust"] },
          "summary": { "type": "string", "enum": ["passed", "failed"] },
          "exit_code": { "type": "integer", "enum": [0, 1] },
          "metrics": {
            "type": "object",
            "required": [
              "checks_passed",
              "checks_failed",
              "checks_skipped",
              "checks_total",
              "pass_rate",
              "frontier_stress_rate",
              "recovery_rate",
              "control_plane_rate",
              "distributed_longevity_rate",
              "soak_ready"
            ],
            "properties": {
              "checks_passed": { "type": "integer", "minimum": 0 },
              "checks_failed": { "type": "integer", "minimum": 0 },
              "checks_skipped": { "type": "integer", "minimum": 0 },
              "checks_total": { "type": "integer", "minimum": 0 },
              "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "frontier_stress_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "recovery_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "control_plane_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "distributed_longevity_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
              "soak_ready": { "type": "boolean" }
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "status", "details"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
                "details": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
