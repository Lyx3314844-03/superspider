{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spider/schemas/spider-smoke-report.schema.json",
  "title": "Spider Smoke Report Contract",
  "type": "object",
  "required": ["command", "summary", "summary_text", "exit_code", "checks"],
  "properties": {
    "command": {
      "const": "smoke-test"
    },
    "summary": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "runtime", "summary", "exit_code", "details"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "enum": ["java", "python", "go", "rust"]
          },
          "summary": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0
          },
          "details": {
            "type": "string"
          }
        }
      }
    }
  }
}
