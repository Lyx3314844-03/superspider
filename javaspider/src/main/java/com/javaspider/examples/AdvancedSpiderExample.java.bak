package com.javaspider.examples;

import com.javaspider.antibot.AntiBotHandler;
import com.javaspider.antibot.CaptchaSolver;
import com.javaspider.browser.BrowserManager;
import com.javaspider.browser.FormFiller;
import com.javaspider.core.Spider;
import com.javaspider.extractor.AIExtractor;
import com.javaspider.extractor.SpiderConfig;
import com.javaspider.model.Page;
import com.javaspider.model.Site;
import com.javaspider.pipeline.ConsolePipeline;
import com.javaspider.pipeline.JsonFilePipeline;
import com.javaspider.processor.PageProcessor;
import com.javaspider.schedule.SpiderScheduler;
import com.javaspider.transformer.DataTransformer;
import com.javaspider.web.WebConsole;

import java.util.*;

/**
 * JavaSpider 综合示例
 * 展示所有高级功能的使用方式
 */
public class AdvancedSpiderExample {

    public static void main(String[] args) {
        System.out.println("=== JavaSpider 高级功能演示 ===\n");

        // 1. 简单爬虫示例
        simpleSpider();

        // 2. 浏览器自动化示例
        browserAutomation();

        // 3. 反爬处理示例
        antiBotExample();

        // 4. AI 内容提取示例
        aiExtractionExample();

        // 5. 数据转换示例
        dataTransformerExample();

        // 6. 定时任务示例
        scheduledTaskExample();

        // 7. Web 控制台示例
        webConsoleExample();

        // 8. 可视化配置示例
        configBuilderExample();
    }

    /**
     * 1. 简单爬虫示例
     */
    private static void simpleSpider() {
        System.out.println("1. 简单爬虫示例");

        Spider.create(new PageProcessor() {
            private final Site site = Site.create();

            @Override
            public void process(Page page) {
                // 提取标题
                String title = page.cssFirst("title");
                page.putField("title", title);

                // 提取所有链接
                page.putField("links", page.getLinks());

                System.out.println("  标题：" + title);
                System.out.println("  链接数：" + page.getLinks().size());
            }

            @Override
            public Site getSite() {
                return site;
            }
        })
        .site(Site.create()
                .addStartUrl("https://www.example.com")
                .setSleepTime(500))
        .threadCount(3)
        .addPipeline(new ConsolePipeline())
        .build()
        .start();
    }

    /**
     * 2. 浏览器自动化示例（处理 JavaScript 渲染页面）
     */
    private static void browserAutomation() {
        System.out.println("\n2. 浏览器自动化示例");
        
        BrowserManager browser = BrowserManager.headless();
        try {
            // 导航到页面
            browser.navigate("https://www.example.com");
            
            // 等待页面加载
            browser.waitForPageLoad();
            
            // 获取渲染后的 HTML
            String html = browser.getPageSource();
            System.out.println("  页面标题：" + browser.getTitle());
            System.out.println("  HTML 长度：" + html.length());
            
            // 截图
            browser.screenshotToFile("screenshot.png");
            System.out.println("  截图已保存");
            
        } finally {
            browser.close();
        }
    }

    /**
     * 3. 反爬处理示例
     */
    private static void antiBotExample() {
        System.out.println("\n3. 反爬处理示例");

        // 创建反爬处理器
        AntiBotHandler antiBot = new AntiBotHandler();

        // 获取随机请求头
        Map<String, String> headers = antiBot.getRandomHeaders();
        System.out.println("  随机 User-Agent: " + headers.get("User-Agent"));

        // 检测是否触发反爬
        String normalHtml = "<html><body>Normal content</body></html>";
        String blockedHtml = "<html><body>Access denied. Bot detected</body></html>";

        boolean isNormal = antiBot.isBlocked(normalHtml, 200);
        boolean isBlocked = antiBot.isBlocked(blockedHtml, 403);

        System.out.println("  正常页面检测：" + (isNormal ? "触发" : "正常"));
        System.out.println("  封锁页面检测：" + (isBlocked ? "触发" : "正常"));
    }

    /**
     * 4. AI 内容提取示例
     */
    private static void aiExtractionExample() {
        System.out.println("\n4. AI 内容提取示例");
        
        // 注意：需要真实的 API Key 才能运行
        // AIExtractor extractor = AIExtractor.openai("your-api-key");
        
        String sampleText = "Apple Inc. announced record earnings today. " +
                          "The company's CEO Tim Cook said the iPhone sales exceeded expectations.";
        
        // 模拟 AI 提取结果
        System.out.println("  原文：" + sampleText);
        System.out.println("  提取实体：{company: Apple Inc., person: Tim Cook, product: iPhone}");
        System.out.println("  情感分析：positive (0.85)");
        System.out.println("  关键词：[Apple, earnings, iPhone, sales]");
        
        // 实际使用方式：
        // Map<String, Object> entities = extractor.extractEntities(sampleText);
        // AIExtractor.SentimentResult sentiment = extractor.analyzeSentiment(sampleText);
        // List<String> keywords = extractor.extractKeywords(sampleText, 5);
    }

    /**
     * 5. 数据转换示例
     */
    private static void dataTransformerExample() {
        System.out.println("\n5. 数据转换示例");
        
        // 原始数据
        Map<String, Object> rawData = new HashMap<>();
        rawData.put("title", "  <p>Hello World</p>  ");
        rawData.put("price", "19.99");
        rawData.put("date", "2024-01-15");
        rawData.put("email", "test@example.com");
        rawData.put("phone", null);
        
        System.out.println("  原始数据：" + rawData);
        
        // 创建转换器
        DataTransformer transformer = DataTransformer.create()
            .addTrimRule("title")
            .addHtmlCleanRule("title")
            .addDateFormatRule("date", "yyyy/MM/dd")
            .addNullRule("phone", "N/A")
            .addValidateRule("email", DataTransformer.Validators.EMAIL);
        
        // 转换数据
        Map<String, Object> cleaned = transformer.transform(rawData);
        
        System.out.println("  转换后：" + cleaned);
    }

    /**
     * 6. 定时任务示例
     */
    private static void scheduledTaskExample() {
        System.out.println("\n6. 定时任务示例");

        SpiderScheduler scheduler = SpiderScheduler.create();

        // 添加定时任务（每分钟执行一次）
        scheduler.addJob("minute-crawl", () -> {
            System.out.println("  [定时任务] 执行爬取任务...");
            return Spider.create(new SimplePageProcessor()).build();
        }, "0 * * * * ?");

        // 添加延迟任务（5 秒后执行）
        scheduler.addDelayedJob("delayed-crawl", () -> {
            System.out.println("  [延迟任务] 执行爬取任务...");
            return Spider.create(new SimplePageProcessor()).build();
        }, 5);

        System.out.println("  已创建定时任务");
        System.out.println("  Cron: 0 * * * * ? (每分钟执行)");

        // 实际使用时需要保持调度器运行
        // scheduler.start();
    }

    /**
     * 简单的页面处理器用于示例
     */
    static class SimplePageProcessor implements PageProcessor {
        private final Site site = Site.create();

        @Override
        public void process(Page page) {
            System.out.println("  Processing: " + page.getUrl());
        }

        @Override
        public Site getSite() {
            return site;
        }
    }

    /**
     * 7. Web 控制台示例
     */
    private static void webConsoleExample() {
        System.out.println("\n7. Web 控制台示例");

        WebConsole console = WebConsole.create(8080);

        // 创建示例爬虫
        Spider spider = Spider.create(new SimplePageProcessor())
                .site(Site.create().addStartUrl("https://example.com"))
                .name("demo-spider")
                .build();

        // 注册爬虫
        console.registerSpider("demo-spider", spider);

        System.out.println("  Web 控制台已启动");
        System.out.println("  访问地址：http://localhost:8080");
        System.out.println("  功能：查看爬虫状态、启动/停止爬虫、查看统计信息");

        // 实际使用时需要保持控制台运行
        // console.start();
    }

    /**
     * 8. 可视化配置示例
     */
    private static void configBuilderExample() {
        System.out.println("\n8. 可视化配置示例");

        // 使用配置构建器创建爬虫
        SpiderConfig config = SpiderConfig.create()
            .name("News Crawler")
            .description("爬取新闻网站")
            .startUrl("https://news.example.com")
            .startUrl("https://news.example.com/page/2")
            .allowedDomain("news.example.com")
            .excludedPattern(".*logout.*")
            .threadCount(10)
            .sleepTime(500)
            .retryTimes(3)
            .extractRule(new SpiderConfig.ExtractRule("title", "h1", "css"))
            .extractRule(new SpiderConfig.ExtractRule("content", ".article-body", "css"))
            .extractRule(new SpiderConfig.ExtractRule("author", "//span[@class='author']", "xpath"))
            .linkRule(new SpiderConfig.LinkRule("a.next-page"));

        String json = config.toJson();

        System.out.println("  配置 JSON:");
        System.out.println(json);

        // 从 JSON 加载配置
        // SpiderConfig loadedConfig = SpiderConfig.fromJson(json);
        // Spider actualSpider = loadedConfig.build();
    }
}

/**
 * 完整爬虫示例：带登录、验证码处理、数据持久化
 */
class CompleteCrawlerExample {

    public static void run() {
        // 1. 配置反爬处理
        AntiBotHandler antiBot = new AntiBotHandler();

        // 2. 配置验证码处理
        CaptchaSolver captchaSolver = CaptchaSolver.twoCaptcha("your-api-key");

        // 3. 创建爬虫
        Spider spider = Spider.create(new LoginProcessor())
            .site(Site.create()
                .addStartUrl("https://example.com/login")
                .addCookie("session", "session-id"))
            .threadCount(5)
            .addPipeline(new JsonFilePipeline("output/data"))
            .build();

        // 4. 启动爬虫
        spider.start();
    }
    
    /**
     * 登录页面处理器
     */
    static class LoginProcessor implements PageProcessor {
        private final Site site = Site.create();
        private boolean loggedIn = false;
        
        @Override
        public void process(Page page) {
            if (!loggedIn) {
                // 执行登录
                performLogin(page);
                loggedIn = true;
            }
            
            // 正常爬取逻辑
            extractData(page);
        }
        
        private void performLogin(Page page) {
            // 添加登录请求
            com.javaspider.model.Request loginRequest = com.javaspider.model.Request.post("https://example.com/api/login")
                    .withRequestBody("{\"user\":\"admin\",\"pass\":\"123456\"}")
                    .addHeader("Content-Type", "application/json");
            page.addTargetRequest(loginRequest);
        }
        
        private void extractData(Page page) {
            // 提取数据
            page.putField("title", page.cssFirst("h1"));
            page.putField("content", page.cssFirst(".content"));
        }
        
        @Override
        public Site getSite() {
            return site;
        }
    }
}
