package main

import (
	"fmt"
	"gospider/enhanced"
	"gospider/dynamic"
	"gospider/parser"
	"strings"
	"time"
	"os"
	"regexp"
	"encoding/json"
)

// YouTubePlaylistSpider YouTube 播放列表爬虫
type YouTubePlaylistSpider struct {
	*enhanced.YouTubeSpiderBase
	headless bool
	crawler  *dynamic.DynamicCrawler
	html     string
}

// NewYouTubePlaylistSpider 创建爬虫
func NewYouTubePlaylistSpider(playlistURL string, headless bool) *YouTubePlaylistSpider {
	settings := map[string]interface{}{
		"headless": headless,
	}
	
	spider := &YouTubePlaylistSpider{
		YouTubeSpiderBase: enhanced.NewYouTubeSpiderBase(playlistURL, settings),
		headless: headless,
	}
	spider.Platform = "Go/gospider"
	
	return spider
}

// Initialize 初始化
func (s *YouTubePlaylistSpider) Initialize() error {
	fmt.Println("🚀 启动浏览器 (Rod)...")
	
	// 创建动态爬虫（使用浏览器）
	s.crawler = dynamic.NewDynamicCrawler(!s.headless, 60*time.Second)
	
	fmt.Println("   ✓ 浏览器已启动")
	return nil
}

// Navigate 导航
func (s *YouTubePlaylistSpider) navigate() error {
	fmt.Println("🌐 正在加载播放列表页面...")
	
	if err := s.crawler.Navigate(s.PlaylistURL); err != nil {
		return fmt.Errorf("导航失败：%w", err)
	}
	
	fmt.Println("   ⏳ 等待页面加载...")
	time.Sleep(5 * time.Second)
	
	// 检查是否需要验证
	content, _ := s.crawler.GetContent()
	if strings.Contains(strings.ToLower(content), "just a moment") {
		fmt.Println("   ⚠️  检测到验证页面，等待绕过...")
		time.Sleep(10 * time.Second)
	}
	
	fmt.Println("   ✓ 页面已加载")
	return nil
}

// WaitAndScroll 滚动加载
func (s *YouTubePlaylistSpider) waitAndScroll() error {
	fmt.Println("📜 滚动加载所有视频...")
	
	// 滚动加载
	s.crawler.ScrollAndLoad(1000, 10)
	
	time.Sleep(3 * time.Second)
	fmt.Println("   ✓ 滚动完成")
	return nil
}

// ExtractContent 提取内容
func (s *YouTubePlaylistSpider) extractContent() error {
	fmt.Println("📄 获取页面内容...")
	
	content, err := s.crawler.GetContent()
	if err != nil {
		return fmt.Errorf("获取内容失败：%w", err)
	}
	
	s.html = content
	
	// 保存 HTML 用于调试
	err = os.WriteFile("youtube_playlist_source.html", []byte(s.html), 0644)
	if err != nil {
		return fmt.Errorf("保存 HTML 失败：%w", err)
	}
	
	fmt.Println("   ✓ HTML 已保存到：youtube_playlist_source.html")
	return nil
}

// ParseVideos 解析视频
func (s *YouTubePlaylistSpider) parseVideos() error {
	fmt.Println("🔍 解析视频信息...")
	
	// 方法 1: 正则解析
	s.Videos = s.parseWithRegex()
	
	// 方法 2: 如果正则失败，尝试备用方法
	if len(s.Videos) == 0 {
		fmt.Println("   尝试使用备用解析方法...")
		s.Videos = s.parseWithBackup()
	}
	
	fmt.Printf("   ✓ 共解析 %d 个视频\n", len(s.Videos))
	return nil
}

// parseWithRegex 使用正则解析
func (s *YouTubePlaylistSpider) parseWithRegex() []*enhanced.VideoItem {
	var videos []*enhanced.VideoItem
	seenTitles := make(map[string]bool)

	// 查找所有视频项
	p := parser.NewHTMLParser(s.html)
	elements := p.CSS("ytd-playlist-panel-video-renderer")

	fmt.Printf("   找到 %d 个视频元素\n", len(elements))

	// 由于 parser 包的限制，我们直接使用备用方法提取

	// 使用备用方法提取
	if len(videos) == 0 {
		titles := p.CSS("#video-title")
		for _, title := range titles {
			if title == "" || seenTitles[title] {
				continue
			}
			seenTitles[title] = true

			video := &enhanced.VideoItem{
				Index: len(videos) + 1,
				Title: title,
			}
			videos = append(videos, video)
		}
	}
	
	return videos
}

// parseWithBackup 备用解析方法
func (s *YouTubePlaylistSpider) parseWithBackup() []*enhanced.VideoItem {
	var videos []*enhanced.VideoItem
	seenTitles := make(map[string]bool)
	
	p := parser.NewHTMLParser(s.html)
	
	// 直接提取所有视频标题
	allTitles := p.CSS("a#video-title")
	for _, title := range allTitles {
		if title == "" || seenTitles[title] {
			continue
		}
		seenTitles[title] = true
		
		video := &enhanced.VideoItem{
			Index: len(videos) + 1,
			Title: title,
		}
		videos = append(videos, video)
	}
	
	return videos
}

// Cleanup 清理
func (s *YouTubePlaylistSpider) cleanup() {
	if s.crawler != nil {
		fmt.Println("\n🔒 关闭浏览器...")
		s.crawler.Close()
		fmt.Println("   ✓ 浏览器已关闭")
	}
}

// SaveResults 保存结果（重写以支持中文）
func (s *YouTubePlaylistSpider) SaveResults() {
	fmt.Println("\n💾 导出结果...")
	
	// 保存为 JSON
	jsonData := map[string]interface{}{
		"playlist_url": s.PlaylistURL,
		"crawl_stats":  s.Stats,
		"videos":       s.Videos,
	}
	
	jsonFile, _ := os.Create("youtube_playlist_result.json")
	defer jsonFile.Close()
	encoder := json.NewEncoder(jsonFile)
	encoder.SetIndent("", "  ")
	encoder.SetEscapeHTML(false)
	encoder.Encode(jsonData)
	fmt.Println("   ✓ JSON 已保存：youtube_playlist_result.json")
	
	// 保存为 TXT
	txtFile, _ := os.Create("youtube_playlist_result.txt")
	defer txtFile.Close()
	
	fmt.Fprintln(txtFile, "YouTube 播放列表视频列表")
	fmt.Fprintln(txtFile, strings.Repeat("═", 60))
	fmt.Fprintln(txtFile)
	fmt.Fprintf(txtFile, "播放列表 URL: %s\n", s.PlaylistURL)
	fmt.Fprintf(txtFile, "爬取时间：%s\n", s.Stats.StartTime)
	fmt.Fprintf(txtFile, "视频总数：%d\n", s.Stats.TotalVideos)
	fmt.Fprintf(txtFile, "唯一频道数：%d\n", s.Stats.UniqueChannels)
	fmt.Fprintf(txtFile, "爬取耗时：%.2f 秒\n\n", s.Stats.CrawlTime)
	fmt.Fprintln(txtFile, strings.Repeat("═", 60))
	fmt.Fprintln(txtFile)
	
	for i, video := range s.Videos {
		fmt.Fprintf(txtFile, "%d. %s\n", i+1, video.Title)
		if video.Duration != "" {
			fmt.Fprintf(txtFile, "   时长：%s\n", video.Duration)
		}
		if video.Channel != "" {
			fmt.Fprintf(txtFile, "   频道：%s\n", video.Channel)
		}
		if video.URL != "" {
			fmt.Fprintf(txtFile, "   链接：%s\n", video.URL)
		}
		fmt.Fprintln(txtFile)
	}
	
	fmt.Println("   ✓ TXT 已保存：youtube_playlist_result.txt")
}

func main() {
	playlistURL := "https://www.youtube.com/watch?v=tr5yZ2TzXaY&list=PLRuPQZBVD6vV89UKIzUwZFUhDx9DjXLxc"
	
	fmt.Println("\n" + strings.Repeat("╔", 30))
	fmt.Println(strings.Repeat("║", 10) + " Go/gospider - YouTube 爬虫 " + strings.Repeat("║", 10))
	fmt.Println(strings.Repeat("╚", 30))
	fmt.Printf("\n📺 播放列表：%s\n\n", playlistURL)
	
	// 创建爬虫
	spider := NewYouTubePlaylistSpider(playlistURL, true)
	
	// 初始化
	spider.Initialize()
	defer spider.cleanup()
	
	// 导航
	spider.navigate()
	
	// 滚动加载
	spider.waitAndScroll()

	// 提取内容
	spider.extractContent()

	// 解析视频
	spider.parseVideos()

	// 计算统计
	spider.afterExtract()
	spider.calculateStats()

	// 打印结果
	spider.printResults()

	// 保存结果
	spider.SaveResults()

	if len(spider.Videos) > 0 {
		fmt.Println("\n✅ 爬取完成!")
	} else {
		fmt.Println("\n⚠️  未找到视频")
	}
}
